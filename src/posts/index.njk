---
layout: base.njk
title: Les Manuscrits
description: "Authored works, research papers, doctrines, essays, and complete texts emerging from the archive."
permalink: /posts/index.html
eleventyExcludeFromCollections: true
---
<section class="masthead">
  <div class="section-inner">
    <p class="section-label">L'Œuvre / Les Manuscrits</p>
    <h1>Les Manuscrits</h1>
    <p class="tagline">{{ description }}</p>
  </div>
</section>

<section class="evidence-band">
  <div class="section-inner">
    <div class="signal-map">
      <p class="entry-note">
        <a href="/feed.xml">Subscribe to the manuscript feed</a>. L'Archive
        remains the complete evidence record.
      </p>

      <section class="signal-section" aria-labelledby="signal-entries-heading">
        <p class="section-label">{{ collections.posts | countLabel("entry", "entries") }}</p>
        <h2 id="signal-entries-heading">Manuscripts, newest first.</h2>
        <ol class="signal-entry-list" aria-label="All manuscripts">
          {% for post in collections.posts | reverse %}
          <li>
            <header>
              <span>{% if post.data.entry %}Entry {{ post.data.entry }}{% else %}Entry{% endif %}</span>
              <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
            </header>
            <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
            <p class="entry-note">
              {% if post.data.type %}{{ post.data.type }}{% else %}Manuscript{% endif %}
              {% if post.data.category %}/ {{ post.data.category }}{% endif %}
            </p>
            {% if post.data.description %}
            <p>{{ post.data.description }}</p>
            {% endif %}
          </li>
          {% endfor %}
        </ol>
      </section>

    </div>
  </div>
</section>
