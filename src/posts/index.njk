---
layout: base.njk
title: Le Signal
description: "Curated public writing from Forgotten Industries: essays, field doctrine, and long-form entries suitable for the public feed."
permalink: /posts/index.html
eleventyExcludeFromCollections: true
---
<section class="masthead">
  <div class="section-inner">
    <p class="section-label">Public writing / RSS</p>
    <h1>Le Signal</h1>
    <p class="tagline">{{ description }}</p>
  </div>
</section>

<section class="evidence-band">
  <div class="section-inner">
    <p class="entry-note mb-5">
      <a href="/feed.xml">Subscribe to the public writing feed</a>. L'Archive
      remains the complete master record.
    </p>
    <ul class="lane-list" aria-label="All posts">
      {% for post in collections.posts | reverse %}
      <li>
        <span>
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
          {% if post.data.type %}/ {{ post.data.type }}{% endif %}
        </span>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        {% if post.data.description %}
        <p>{{ post.data.description }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
</section>
