---
layout: base.njk
title: Field Logs
description: "Authored field reports from Forgotten Industries: bench observations, process notes, and small dated records that belong under Le Signal."
permalink: /field-logs/index.html
eleventyExcludeFromCollections: true
---

<section class="masthead">
  <div class="section-inner">
    <p class="section-label">Le Signal / field reports</p>
    <h1>Field Reports</h1>
    <p class="tagline">{{ description }}</p>
  </div>
</section>

<section class="source-band" aria-labelledby="field-logs-status">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Short Form</p>
      <h2 id="field-logs-status">A pocket notebook for the archive.</h2>
    </div>

    <div class="callout">
      <h3>Report Lane</h3>
      <p>Field reports are authored notes: shorter than doctrine, more deliberate than the live Bluesky signal, and dated for later recovery.</p>
      <p class="action-row"><a href="/archive/field-logs/">Open structured archive records</a></p>
    </div>
  </div>
</section>

<section class="evidence-band" aria-labelledby="field-logs-list">
  <div class="section-inner">
    <div class="field-notes-heading">
      <p class="section-label">{{ archive.fieldLogs | count }} records</p>
      <h2 id="field-logs-list">Small records before they become essays, dossiers, or methods.</h2>
    </div>

    {% if archive.fieldLogs.length %}
    <ol class="field-note-list">
      {% for log in archive.fieldLogs | reverse %}
      <li class="field-note-card">
        <header>
          <time datetime="{{ log.date }}">{{ log.date | replace('-', '.') | replace('-', '.') }}</time>
          <span>{{ log.category }}</span>
        </header>
        <h3>{{ log.title }}</h3>
        <p>{{ log.object }}. {{ log.status }}.</p>
        {% if log.tags and log.tags.length %}
        <footer aria-label="Field log tags">
          {% for tag in log.tags %}
          <span>{{ tag }}</span>
          {% endfor %}
        </footer>
        {% endif %}
      </li>
      {% endfor %}
    </ol>
    {% else %}
    <div class="callout field-note-empty">
      <h3>No Logs Yet</h3>
      <p>The route is active. Add dated field-log records when the daily writing lane is ready.</p>
    </div>
    {% endif %}
  </div>
</section>
