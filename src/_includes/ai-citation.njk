<aside class="ai-citation" role="note" aria-label="AI generation citation">
  <p class="section-label">{{ aiCitationLabel or "AI generation citation" }}</p>
  <p>{{ aiCitationDisclosure }}</p>
  <p class="ai-citation-reference">
    <strong>Citation:</strong> {{ aiCitationReference }}
  </p>
  <p class="entry-note">
    <a href="{{ site.aiProvenance.colophonUrl }}">AI colophon</a> /
    <a href="{{ site.aiProvenance.standardUrl }}">citation standard</a>
  </p>
</aside>
