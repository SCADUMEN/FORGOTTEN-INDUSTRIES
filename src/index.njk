---
layout: base.njk
title: Forgotten Industries
description: An archive and evidence-based memoir.
canonical: https://forgotten-industries.net/
---
{% set reports = archive.fieldLogs | fieldLogsNewest %}
{% set latestReport = reports[0] %}
{% set latestPost = collections.posts | latestCollectionItem %}
{% set latestProject = archive.projects | latestRecord %}
{% set latestObject = archive.inventory | latestRecord %}
{% set latestRestoration = archive.projects | latestRestoration %}

<section class="institution-hero" aria-labelledby="home-title">
  <div class="section-inner">
    <p class="section-label">Archive &amp; evidence-based memoir / established MMXIV</p>
    <h1 id="home-title">Forgotten Industries</h1>
    <p class="institution-subtitle">An archive and evidence-based memoir.</p>
    <p class="institution-doctrine">A thing documented is a thing not yet lost.</p>
  </div>
</section>

<section class="primary-finding-aid" aria-label="Primary archive sections">
  <div class="section-inner primary-card-grid">
    <a class="primary-section-card" href="/archive/">
      <span>01 / Preserved</span>
      <h2>L'Archive</h2>
      <p>The Preserved Record</p>
      <em>Everything catalogued, sourced, and kept.</em>
    </a>
    <a class="primary-section-card" href="/oeuvre/">
      <span>02 / Active</span>
      <h2>L'Œuvre</h2>
      <p>The Active Record</p>
      <em>Projects, restorations, dossiers, and work underway.</em>
    </a>
    <a class="primary-section-card" href="/signal/">
      <span>03 / Authored</span>
      <h2>Le Signal</h2>
      <p>The Authored Record</p>
      <em>Reports, field logs, live dispatches, and essays.</em>
    </a>
    <a class="primary-section-card" href="/apropos/">
      <span>04 / Maker Plate</span>
      <h2>À Propos</h2>
      <p>The Maker Plate</p>
      <em>Authorship, methods, provenance, source, and contact.</em>
    </a>
  </div>
</section>

<section class="instrument-strip" aria-labelledby="archive-state-heading">
  <div class="section-inner">
    <h2 id="archive-state-heading" class="sr-only">Archive state</h2>
    <div class="stats homepage-instrument-stats">
      <a class="stat" href="/projects/">
        <strong>{{ archive.projects | count }}</strong>
        <span>Projets</span>
      </a>
      <a class="stat" href="/hang-on-to-each-other/">
        <strong>1</strong>
        <span>Manuels</span>
      </a>
      <a class="stat" href="/atlas/">
        <strong>{{ archive.fieldLogs | count }}</strong>
        <span>ATLAS Reports</span>
      </a>
      <a class="stat" href="/social-posts.html">
        <strong>{{ archive.socialPosts | count }}</strong>
        <span>Social Records</span>
      </a>
      <a class="stat" href="{{ site.githubUrl }}">
        <strong>{{ site.sourceStats.sourceFiles }}</strong>
        <span>Source Files</span>
      </a>
    </div>
  </div>
</section>

<section class="latest-activity" aria-labelledby="latest-activity-heading">
  <div class="section-inner">
    <p class="section-label">Latest Activity</p>
    <h2 id="latest-activity-heading" class="sr-only">Latest activity across the archive</h2>
    <div class="activity-strip">
      <a href="{{ latestPost.url }}">
        <span>Latest Signal</span>
        <strong>{{ latestPost.data.title }}</strong>
      </a>
      <a href="{{ latestProject | archiveProjectUrl }}">
        <span>Latest Project</span>
        <strong>{{ latestProject.title }}</strong>
      </a>
      <a href="{{ latestObject | archiveObjectUrl }}">
        <span>Latest Archive Entry</span>
        <strong>{{ latestObject.name }}</strong>
      </a>
      <a href="{{ latestRestoration | archiveProjectUrl }}">
        <span>Latest Restoration</span>
        <strong>{{ latestRestoration.title }}</strong>
      </a>
    </div>
    {% if latestReport %}
    <p class="latest-report-line"><span>Latest ATLAS Report</span> <a href="/field-logs/{{ latestReport.slug }}/">{{ latestReport.title }}</a></p>
    {% endif %}
  </div>
</section>

<section class="open-stacks" aria-labelledby="open-stacks-heading">
  <div class="section-inner">
    <p class="section-label">Open Stacks</p>
    <h2 id="open-stacks-heading">Direct access. No intermediary.</h2>
    <nav class="open-stacks-list" aria-label="Direct archive access">
      <a href="/inventory.html">Inventory</a>
      <a href="/hang-on-to-each-other/">Les Manuels</a>
      <a href="/social-posts.html">Social Evidence</a>
      <a href="/dist/archive.json">Archive JSON</a>
      <a href="/docs/process/">Process Records</a>
      <a href="{{ site.githubUrl }}">La Source</a>
    </nav>
  </div>
</section>
