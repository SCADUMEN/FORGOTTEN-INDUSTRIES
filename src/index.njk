      <h2 id="shelves-heading">The site spine is an archive map.</h2>
    </div>

    <ul class="shelf-list">
      {% for shelf in site.shelves %}
      <li>
        <h3 id="{{ shelf.slug }}">{% if shelf.href %}<a href="{{ shelf.href }}">{{ shelf.label }}</a>{% else %}{{ shelf.label }}{% endif %}</h3>
        <p>{{ shelf.purpose }}</p>
        <p class="shelf-note">{{ shelf.tone }} {{ shelf.note }}</p>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

