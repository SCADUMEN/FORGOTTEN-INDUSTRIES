---
layout: base.njk
pagination:
  data: archive.inventory
  size: 1
  alias: object
permalink: "/archive/objects/{{ object.id | archiveSlug }}/"
eleventyComputed:
  title: "L'Archive / Object / {{ object.name }}"
  description: "{{ object.condition }}. {{ object.status }}."
  image: "{{ object | objectPrimaryImage }}"
  imageAlt: "{{ object.id }} — {{ object.name }}"
eleventyExcludeFromCollections: true
---
{% set publicPhotos = object | publicObjectPhotos %}
{% set sourcePhotos = object.photos or [] %}
{% set captionPrefix = object.id + " / " + object.name + " / source photograph " %}
{% set project = archive.projects | findById(object.associated_project) %}
{% set relatedObjects = archive.inventory | relatedObjects(object) %}
{% set projectLogs = archive.fieldLogs | fieldLogsForProject(object.associated_project) %}

<article class="object-record">
  <header class="section-landing-hero object-record-hero">
    <div class="section-inner">
      <p class="section-label">Object Record / {{ object.id }}</p>
      <h1>{{ object.name }}</h1>
      <p class="tagline">{{ object.condition }} / {{ object.status }}</p>
    </div>
  </header>

  <section class="object-visual-band" aria-labelledby="object-visual-heading">
    <div class="section-inner">
      <div class="object-section-heading">
        <p class="section-label">Primary evidence</p>
        <h2 id="object-visual-heading">The object before the record.</h2>
      </div>

      {% if publicPhotos.length %}
      <figure class="object-primary-figure">
        <a href="/{{ publicPhotos[0] }}" data-object-primary-link>
          <img
            src="/{{ publicPhotos[0] }}"
            alt="{{ object.id }} — {{ object.name }}"
            data-object-primary-image
          >
        </a>
        <figcaption data-object-primary-caption>{{ object.id }} / {{ object.name }} / source photograph 01</figcaption>
      </figure>

      {% if publicPhotos.length > 1 %}
      <div class="object-thumbnail-strip" aria-label="Additional source photographs">
        {% for photo in publicPhotos %}
        <a
          href="/{{ photo }}"
          data-object-thumbnail
          data-photo-index="{{ loop.index }}"
          {% if loop.first %}aria-current="true"{% endif %}
        >
          <img
            src="/{{ photo }}"
            alt="{{ object.id }} — {{ object.name }} / source photograph {{ loop.index }}"
            loading="lazy"
          >
          <span>Photo {{ loop.index }}</span>
        </a>
        {% endfor %}
      </div>
      {% endif %}
      {% else %}
      <div class="object-image-placeholder" role="img" aria-label="No image available for {{ object.id }} — {{ object.name }}">
        <span>{{ object.id }}</span>
        <strong>No image available</strong>
        <p>Source photography has not yet been registered for this object.</p>
      </div>
      {% endif %}
    </div>
  </section>

  <section class="source-band object-metadata-band" aria-labelledby="object-metadata-heading">
    <div class="section-inner">
      <div class="object-section-heading">
        <p class="section-label">Catalog state / {{ object.category }}</p>
        <h2 id="object-metadata-heading">Metadata supports the object.</h2>
      </div>

      <dl class="object-metadata-grid">
        <div>
          <dt>Identity</dt>
          <dd>{{ object.id }} / {{ object.manufacturer or "Unknown manufacturer" }}{% if object.model %} / {{ object.model }}{% endif %}</dd>
        </div>
        <div>
          <dt>Dossier</dt>
          <dd>{% if project %}<a href="{{ project | archiveProjectUrl }}">{{ project.title }}</a>{% else %}{{ object.associated_project or "Unassigned" }}{% endif %}</dd>
        </div>
        <div>
          <dt>Condition</dt>
          <dd>{{ object.condition }}</dd>
        </div>
        <div>
          <dt>Status</dt>
          <dd>{{ object.status }}</dd>
        </div>
        <div>
          <dt>Disposition</dt>
          <dd>{{ object.keep_sell_archive or "Unassigned" }}</dd>
        </div>
        <div>
          <dt>Build relevance</dt>
          <dd>{% if project %}{{ project.status }} / {{ project.category }}{% else %}No dossier relationship recorded.{% endif %}</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="evidence-band object-narrative-band" aria-labelledby="object-narrative-heading">
    <div class="section-inner">
      <div class="object-section-heading">
        <p class="section-label">Narrative record</p>
        <h2 id="object-narrative-heading">Evidence, relevance, and unresolved state.</h2>
      </div>

      <div class="object-narrative-grid">
        <section>
          <p class="section-label">Provenance</p>
          <h3>Custody record</h3>
          <p>Logged {{ object.date_logged }}{% if object.quantity %} / quantity {{ object.quantity }}{% endif %}. {{ sourcePhotos | countLabel("source asset reference", "source asset references") }} registered.</p>
        </section>
        <section>
          <p class="section-label">Identification notes</p>
          <h3>What is known</h3>
          <p>{{ object.notes or "No identification notes recorded yet." }}</p>
        </section>
        <section>
          <p class="section-label">Restoration relevance</p>
          <h3>Why it remains connected</h3>
          <p>{{ object.status }}. Disposition: {{ object.keep_sell_archive or "unassigned" }}.{% if project %} The object remains associated with <a href="{{ project | archiveProjectUrl }}">{{ project.title }}</a>.{% endif %}</p>
        </section>
        <section>
          <p class="section-label">Uncertainty notes</p>
          <h3>What remains unresolved</h3>
          <p>{{ object.condition }}. {{ object.status }}. Terms marked unknown, provisional, pending, or unverified remain part of the record until evidence resolves them.</p>
        </section>
      </div>
    </div>
  </section>

  <section class="source-band object-relationships-band" aria-labelledby="object-relationships-heading">
    <div class="section-inner band-grid">
      <div>
        <p class="section-label">Relationships</p>
        <h2 id="object-relationships-heading">Keep the object connected.</h2>
      </div>

      <div class="object-relationship-groups">
        {% if relatedObjects.length %}
        <section>
          <p class="section-label">Related objects</p>
          <ul>
            {% for related in relatedObjects %}
            <li><a href="{{ related | archiveObjectUrl }}">{{ related.id }} / {{ related.name }}</a></li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}

        {% if project %}
        <section>
          <p class="section-label">Parent system</p>
          <h3><a href="{{ project | archiveProjectUrl }}">{{ project.title }}</a></h3>
          <p>{{ project.summary }}</p>
          <p class="entry-note">Associated dossier / {{ project.id }} / {{ project.status }}</p>
        </section>
        {% endif %}

        {% if projectLogs.length %}
        <section>
          <p class="section-label">Field logs / dossiers</p>
          <ul>
            {% for log in projectLogs %}
            <li><a href="/field-logs/{{ log.slug }}/">{{ log.title }}</a></li>
            {% endfor %}
          </ul>
        </section>
        {% endif %}

        <section>
          <p class="section-label">Archive routes</p>
          <ul>
            {% if object.archive_entry %}
            <li><a href="{{ object.archive_entry }}">Detailed L'Archive entry</a></li>
            {% endif %}
            <li><a href="/archive/objects/">Object index</a></li>
            <li><a href="/archive/inventory/">Inventory shelf</a></li>
            <li><a href="/archive/categories/{{ object.category | archiveSlug }}/">{{ object.category }} records</a></li>
          </ul>
        </section>
      </div>
    </div>
  </section>

  <section class="evidence-band object-source-assets" aria-labelledby="object-source-assets-heading">
    <div class="section-inner">
      <details>
        <summary id="object-source-assets-heading">Source Assets / {{ sourcePhotos.length | countLabel("reference", "references") }}</summary>
        <p>Raw archive paths are retained for provenance and maintenance. They are not the primary object presentation.</p>
        {% if sourcePhotos.length %}
        <ol>
          {% for photo in sourcePhotos %}
          <li>
            <code>{{ photo }}</code>
            {% if photo.indexOf("assets/") == 0 or photo.indexOf("forgotten-industries/") == 0 %}
            <a href="/{{ photo }}">Open local asset</a>
            {% else %}
            <span>Source path not published</span>
            {% endif %}
          </li>
          {% endfor %}
        </ol>
        {% else %}
        <p class="object-source-empty">No raw source asset path is registered for this object yet.</p>
        {% endif %}
      </details>
    </div>
  </section>
</article>

<script>
  (function() {
    var captionPrefix = {{ captionPrefix | json | safe }};
    var gallery = document.querySelector('.object-record');
    if (!gallery) return;

    var primaryLink = gallery.querySelector('[data-object-primary-link]');
    var primaryImage = gallery.querySelector('[data-object-primary-image]');
    var primaryCaption = gallery.querySelector('[data-object-primary-caption]');
    var thumbnails = gallery.querySelectorAll('[data-object-thumbnail]');
    if (!primaryLink || !primaryImage || !thumbnails.length) return;

    thumbnails.forEach(function(thumbnail) {
      thumbnail.addEventListener('click', function(event) {
        event.preventDefault();
        var image = thumbnail.querySelector('img');
        var index = thumbnail.getAttribute('data-photo-index');
        primaryLink.href = thumbnail.href;
        primaryImage.src = thumbnail.href;
        primaryImage.alt = image ? image.alt : primaryImage.alt;
        if (primaryCaption) {
          primaryCaption.textContent = captionPrefix + String(index).padStart(2, '0');
        }
        thumbnails.forEach(function(item) {
          item.removeAttribute('aria-current');
        });
        thumbnail.setAttribute('aria-current', 'true');
      });
    });
  })();
</script>
