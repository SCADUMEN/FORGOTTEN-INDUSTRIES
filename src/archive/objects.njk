---
layout: base.njk
title: L'Archive / Objects
description: Crawlable Forgotten Industries object and component index.
permalink: /archive/objects/
eleventyExcludeFromCollections: true
---
<section class="masthead">
  <div class="section-inner">
    <p class="section-label">L'Archive / Objects</p>
    <h1>Objects & Components</h1>
    <p class="tagline">
      Physical archive records grouped as durable object pages: machines,
      panels, pumps, radiators, controllers, recovered components, and evidence
      sets.
    </p>
  </div>
</section>

<section class="evidence-band" aria-labelledby="photo-object-prototype-heading">
  <div class="section-inner">
    <div class="archive-gallery-heading">
      <p class="section-label">FI-v2.27 / {{ collections.archiveObjects | count }} prototype records</p>
      <h2 id="photo-object-prototype-heading">Photo archive ingestion prototype.</h2>
      <p>Markdown object entries with structured photo evidence. Sample content only; inventory records below remain canonical.</p>
    </div>

    <ol class="archive-object-prototype-grid">
      {% for entry in collections.archiveObjects | reverse %}
      <li>
        <a href="{{ entry.url }}">
          {% if entry.data.photos and entry.data.photos.length %}
          <img src="{{ entry.data.photos[0].src }}" alt="{{ entry.data.photos[0].alt }}" loading="lazy">
          {% endif %}
          <span class="entry-note">{{ entry.data.category }} / {{ entry.data.status }}</span>
          <h3>{{ entry.data.title }}</h3>
          <p>{{ entry.data.object }} / {{ entry.data.location }}</p>
          <span class="entry-note">{{ entry.date | readableDate }} / {{ entry.data.photos | count }} photo{% if entry.data.photos.length != 1 %}s{% endif %}</span>
        </a>
      </li>
      {% endfor %}
    </ol>
  </div>
</section>

<section class="source-band">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">{{ archive.inventory | count }} records</p>
      <h2>Canonical inventory objects.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for item in archive.inventory %}
      <li>
        <p class="entry-note">
          {{ item.id }} / {{ item.category }} / {{ item.associated_project }}
        </p>
        <h3><a href="{{ item | archiveObjectUrl }}">{{ item.name }}</a></h3>
        <p>{{ item.condition }}. {{ item.status }}.</p>
        <p class="entry-note">
          logged {{ item.date_logged }}{% if item.photos and item.photos.length %}
          / {{ item.photos.length }} photo{% if item.photos.length != 1 %}s{% endif %}{% endif %}
        </p>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>
