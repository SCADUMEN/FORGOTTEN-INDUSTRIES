---
layout: base.njk
title: L'Archive / Field Logs
description: Structured Forgotten Industries field logs and bench evidence records.
permalink: /archive/field-logs/
eleventyExcludeFromCollections: true
---
<section class="masthead">
  <div class="section-inner">
    <p class="section-label">L'Archive / Field Logs</p>
    <h1>Field Logs</h1>
    <p class="tagline">
      Structured bench notes, recovery records, object states, observations,
      methods, and next verification steps.
    </p>
  </div>
</section>

<section class="source-band">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">{{ archive.fieldLogs | count }} records</p>
      <h2>Evidence before interpretation.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for log in archive.fieldLogs | fieldLogsNewest %}
      {% set project = archive.projects | findById(log.associated_project) %}
      <li id="{{ log.id }}">
        <p class="entry-note">{{ log.id }} / {{ log.date }} / {{ log.category }}</p>
        <h3><a href="/field-logs/{{ log.slug }}/">{{ log.title }}</a></h3>
        <p>{{ log.summary or log.object }}</p>
        <p class="entry-note">
          {{ log.object }}{% if log.system %} / {{ log.system }}{% endif %}{% if log.status %} / {{ log.status }}{% endif %}{% if project %} / <a href="{{ project | archiveProjectUrl }}">{{ project.title }}</a>{% endif %}
        </p>
        {% if log.tags and log.tags.length %}
        <p class="entry-note">{{ log.tags | join(', ') }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
</section>
