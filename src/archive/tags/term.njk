---
layout: base.njk
pagination:
  data: taxonomy.tags
  size: 1
  alias: term
permalink: "/archive/tags/{{ term.slug }}/"
eleventyComputed:
  title: "L'Archive / Tag / {{ term.label }}"
  description: "Archive records tagged {{ term.label }}."
eleventyExcludeFromCollections: true
---
<section class="masthead">
  <div class="section-inner">
    <p class="section-label">Tag</p>
    <h1>{{ term.label }}</h1>
    <p class="tagline">{{ term.records.length | countLabel("record", "records") }} with this tag.</p>
  </div>
</section>

<section class="evidence-band">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Records</p>
      <h2>Tag browse.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for record in term.records %}
      <li>
        <p class="entry-note">{{ record.date }} / {{ record.type }} / {{ record.category }}</p>
        <h3><a href="{{ record.url }}">{{ record.title }}</a></h3>
        <p>{{ record.summary | truncate(240) }}</p>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>
