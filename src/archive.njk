    <nav class="hero-door-row" aria-label="L'Archive primary doors">
      <a class="hero-shadow-button" href="#archive-search-heading">
        <span>L'Index</span>
        <strong>Search</strong>
      </a>
      <a class="hero-shadow-button" href="/archive/inventory/">
        <span>Objects</span>
        <strong>Inventory</strong>
      </a>
      <a class="hero-shadow-button" href="/archive/source-sets/">
        <span>Evidence</span>
