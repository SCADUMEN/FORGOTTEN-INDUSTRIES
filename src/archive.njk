<section class="source-band" aria-labelledby="inventory-gallery-heading">
  <div class="section-inner">
    <div class="archive-gallery-heading">
      <p class="section-label">Inventory</p>
      <h2 id="inventory-gallery-heading">Object Gallery</h2>
      <p class="entry-note archive-gallery-note">
        {{ objectPreview | countLabel("record", "records") }} shown / <a href="/archive/objects/">open object ledger</a>
      </p>
    </div>

    <div class="inventory-gallery-viewport" aria-label="Inventory object gallery" tabindex="0">
      <ol class="inventory-gallery-track">
        {% for item in objectPreview %}
        {% set preview = "" %}
        {% if item.photos and item.photos.length %}
        {% set preview = item.photos[0] %}
        {% endif %}
        <li class="inventory-gallery-card">
          <figure>
            <a class="inventory-gallery-image" href="{{ item | archiveObjectUrl }}">
              {% if preview and (preview.indexOf("assets/") == 0 or preview.indexOf("forgotten-industries/") == 0) %}
              <img src="/{{ preview }}" alt="{{ item.name }}">
              {% else %}
              <span>{{ item.id }}</span>
              {% endif %}
            </a>
            <figcaption>
              <span>{{ item.id }}</span>
              <strong><a href="{{ item | archiveObjectUrl }}">{{ item.name }}</a></strong>
              <em>{{ item.category }}</em>
            </figcaption>
          </figure>
        </li>
        {% endfor %}
      </ol>
    </div>
  </div>
</section>

