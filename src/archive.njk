<section class="evidence-band archive-page-section" aria-labelledby="projects-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Projects</p>
      <h2 id="projects-heading">Dossiers and continuity packets.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for project in archive.projects %}
      <li id="{{ project.id }}">
        <p class="entry-note">
          {{ project.id }} / {{ project.category }} / {{ project.status }}
        </p>
        <h3><a href="{{ project | archiveProjectUrl }}">{{ project.title }}</a></h3>
        <p>{{ project.summary }}</p>
        {% if project.working_title %}
        <p class="entry-note">{{ project.working_title }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="source-band archive-page-section" aria-labelledby="field-log-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">ATLAS Reports</p>
      <h2 id="field-log-heading">Evidence before interpretation.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for log in archive.fieldLogs | fieldLogsNewest %}
      {% set project = archive.projects | findById(log.associated_project) %}
      <li id="{{ log.id }}">
        <p class="entry-note">{{ log.id }} / {{ log.date }} / {{ log.category }}</p>
        <h3><a href="/field-logs/{{ log.slug }}/">{{ log.title }}</a></h3>
        <p>{{ log.summary or log.object }}</p>
        <p class="entry-note">
          {{ log.object }}{% if log.system %} / {{ log.system }}{% endif %}{% if log.status %} / {{ log.status }}{% endif %}{% if project %} / <a href="/archive/projects/#{{ project.id }}">{{ project.title }}</a>{% endif %}
        </p>
        {% if log.tags and log.tags.length %}
        <p class="entry-note">{{ log.tags | join(', ') }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="source-band archive-page-section" aria-labelledby="social-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Recovered Social Records</p>
      <h2 id="social-heading">Imported posts remain visible as source records.</h2>
      <p class="entry-note archive-scroll-note">
        {{ archive.socialPosts | count }} records / scroll within ledger
      </p>
    </div>

    <ul
      class="link-list archive-record-list archive-record-viewport"
      aria-label="Scrollable recovered social evidence ledger"
      tabindex="0"
    >
      {% for post in archive.socialPosts | reverse %}
      <li>
        <p class="entry-note">{{ post.date }} / {{ post.source }} / {{ post.source_id }}</p>
        <h3>
          <a href="/{{ post.post_path }}">{{ post.title }}</a>
        </h3>
        <p>{{ post.body | truncate(220) }}</p>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

