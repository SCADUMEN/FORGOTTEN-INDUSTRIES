---
layout: base.njk
title: L'Archive
description: "La premiere providence: the master record for Forgotten Industries inventory, entries, projects, field logs, and recovered evidence."
permalink: /archive.html
eleventyExcludeFromCollections: true
---
<section class="masthead">
  <div class="section-inner">
    <p class="section-label">La premiere providence</p>
    <h1>L'Archive</h1>
    <p class="tagline">
      The master record: inventory items, project dossiers, field logs, curated
      writing, recovered social evidence, source sets, and machine-readable
      archive outputs.
    </p>
  </div>
</section>

<section class="archive-search-band" aria-labelledby="archive-search-heading">
  <div class="section-inner">
    <div class="archive-search-shell">
      <div class="archive-search-intro">
        <p class="section-label">L'Index</p>
        <h2 id="archive-search-heading">Search L'Archive</h2>
        <p class="entry-note">
          Last indexed:
          <span id="archive-search-indexed">{{ site.archiveState }}</span>
          / Query language:
          <code>title:"Pang"</code>
          <code>tag:watercooling</code>
          <code>date&gt;2026-06-01</code>
        </p>
        <p class="archive-search-meta">
          Archive State: <time datetime="{{ site.archiveState }}">{{ site.archiveState }}</time>
          / Build Time: <time datetime="{{ site.buildTime }}">{{ site.buildTime }}</time>
          / Source Commit:
          <a href="{{ site.githubUrl }}/commit/{{ site.gitHash }}">{{ site.gitHashShort }}</a>
          / Generator: {{ site.generator }}
          / Colophon: <a href="/colophon/">/colophon/</a>
        </p>
      </div>

      <form id="archive-search-form" class="archive-search-form" role="search">
        <label class="sr-only" for="archive-search-input">Search L'Archive</label>
        <input
          id="archive-search-input"
          name="q"
          type="search"
          autocomplete="off"
          placeholder='Search the retrieval layer, or try tag:watercooling type:doctrine'
        >
        <button type="submit">Search</button>
      </form>

      <noscript>
        <p class="archive-search-status">JavaScript is required for search.</p>
      </noscript>

      <p id="archive-search-status" class="archive-search-status">Loading L'INDEX...</p>
      <ol id="archive-search-results" class="archive-search-results" aria-live="polite"></ol>
    </div>
  </div>
</section>

<script>
  (function() {
    var form = document.getElementById('archive-search-form');
    var input = document.getElementById('archive-search-input');
    var status = document.getElementById('archive-search-status');
    var results = document.getElementById('archive-search-results');
    var indexed = document.getElementById('archive-search-indexed');
    var documents = [];

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, function(character) {
        return ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;'
        })[character];
      });
    }

    function parseQuery(query) {
      var filters = [];
      var terms = [];
      var pattern = /([a-z]+)(:|>=|<=|>|<)(?:"([^"]+)"|(\S+))|"([^"]+)"|(\S+)/gi;
      var match;

      while ((match = pattern.exec(query)) !== null) {
        if (match[1]) {
          filters.push({
            field: match[1].toLowerCase(),
            op: match[2],
            value: String(match[3] || match[4] || '').toLowerCase()
          });
        } else {
          terms.push(String(match[5] || match[6] || '').toLowerCase());
        }
      }

      return { filters: filters, terms: terms };
    }

    function fieldValue(document, field) {
      if (field === 'tag') field = 'tags';
      if (field === 'shelf') field = 'category';
      if (field === 'after' || field === 'before') field = 'date';
      var value = document[field];
      return Array.isArray(value) ? value.join(' ') : String(value || '');
    }

    function matchesFilter(document, filter) {
      var value = fieldValue(document, filter.field).toLowerCase();
      var filterValue = filter.value;

      if (filter.field === 'after') return String(document.date || '') > filterValue;
      if (filter.field === 'before') return String(document.date || '') < filterValue;
      if (filter.field === 'date' && filter.op === '>') return String(document.date || '') > filterValue;
      if (filter.field === 'date' && filter.op === '<') return String(document.date || '') < filterValue;
      if (filter.field === 'date' && filter.op === '>=') return String(document.date || '') >= filterValue;
      if (filter.field === 'date' && filter.op === '<=') return String(document.date || '') <= filterValue;

      return value.indexOf(filterValue) !== -1;
    }

    function scoreDocument(document, terms) {
      if (!terms.length) return 1;
      var title = String(document.title || '').toLowerCase();
      var summary = String(document.summary || '').toLowerCase();
      var tokens = String(document.tokens || '').toLowerCase();
      var score = 0;

      for (var i = 0; i < terms.length; i += 1) {
        var term = terms[i];
        if (title.indexOf(term) !== -1) score += 5;
        if (summary.indexOf(term) !== -1) score += 3;
        if (tokens.indexOf(term) !== -1) score += 1;
        if (tokens.indexOf(term) === -1) return 0;
      }

      return score;
    }

    function runSearch(query) {
      var parsed = parseQuery(query);
      var matches = documents
        .map(function(document) {
          if (!parsed.filters.every(function(filter) { return matchesFilter(document, filter); })) {
            return null;
          }

          var score = scoreDocument(document, parsed.terms);
          if (!score) return null;
          return { document: document, score: score };
        })
        .filter(Boolean)
        .sort(function(a, b) {
          if (b.score !== a.score) return b.score - a.score;
          return String(b.document.date || '').localeCompare(String(a.document.date || ''));
        })
        .slice(0, 24);

      renderResults(matches, query);
    }

    function renderResults(matches, query) {
      if (!query.trim()) {
        status.textContent = documents.length + ' indexed records / ready';
        results.innerHTML = '';
        return;
      }

      var label = matches.length + ' result' + (matches.length === 1 ? '' : 's');
      status.textContent = label;
      results.innerHTML = matches.map(function(match) {
        var document = match.document;
        var meta = [document.date, document.type, document.category].filter(Boolean).join(' / ');
        var tags = (document.tags || []).slice(0, 8).map(function(tag) {
          return '<span>' + escapeHtml(tag) + '</span>';
        }).join('');

        return [
          '<li>',
          '<p class="entry-note">' + escapeHtml(meta || document.id) + '</p>',
          '<h3><a href="' + escapeHtml(document.url) + '">' + escapeHtml(document.title) + '</a></h3>',
          '<p>' + escapeHtml(document.summary || document.body || 'Indexed archive record.') + '</p>',
          tags ? '<footer aria-label="Search result tags">' + tags + '</footer>' : '',
          '</li>'
        ].join('');
      }).join('');
    }

    function syncQuery(query) {
      input.value = query;
      runSearch(query);
    }

    fetch('/dist/search-index.json?v={{ site.assetVersion }}')
      .then(function(response) { return response.json(); })
      .then(function(index) {
        documents = index.documents || [];
        if (index.archiveState) indexed.textContent = index.archiveState;
        var params = new URLSearchParams(window.location.search);
        syncQuery(params.get('q') || '');
      })
      .catch(function() {
        status.textContent = "L'INDEX failed to load.";
      });

    form.addEventListener('submit', function(event) {
      event.preventDefault();
      var query = input.value.trim();
      var url = new URL(window.location.href);
      if (query) {
        url.searchParams.set('q', query);
      } else {
        url.searchParams.delete('q');
      }
      window.history.replaceState({}, '', url);
      runSearch(query);
    });

    input.addEventListener('input', function() {
      window.clearTimeout(input.searchTimer);
      input.searchTimer = window.setTimeout(function() {
        runSearch(input.value.trim());
      }, 120);
    });
  })();
</script>

<section class="mirror-band" aria-labelledby="archive-counts-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Record State</p>
      <h2 id="archive-counts-heading">Every public route returns here.</h2>
    </div>

    <div>
      <div class="stats" aria-label="Archive record counts">
        <a class="stat" href="/archive/inventory/">
          <strong>{{ archive.inventory | count }}</strong>
          <span>Inventory</span>
        </a>
        <a class="stat" href="/archive/posts/">
          <strong>{{ collections.posts | count }}</strong>
          <span>Curated posts</span>
        </a>
        <a class="stat" href="/archive/field-logs/">
          <strong>{{ archive.fieldLogs | count }}</strong>
          <span>Field logs</span>
        </a>
        <a class="stat" href="/archive/social-evidence/">
          <strong>{{ archive.socialPosts | count }}</strong>
          <span>Social evidence</span>
        </a>
      </div>

      <ul class="lane-list mt-6" aria-label="Primary archive routes">
        <li>
          <a class="panel-link" href="/archive/posts/">
            <span>Public writing</span>
            <h3>Le Signal</h3>
            <p>Curated essays, field doctrine, and long-form entries.</p>
          </a>
        </li>
        <li>
          <a class="panel-link" href="/archive/feed/">
            <span>Feed</span>
            <h3>RSS / Atom</h3>
            <p>The public writing feed. Inventory remains indexed here.</p>
          </a>
        </li>
        <li>
          <a class="panel-link" href="/archive/data/">
            <span>Data</span>
            <h3>Archive JSON</h3>
            <p>Generated from canonical YAML for inspection and reuse.</p>
          </a>
        </li>
      </ul>
    </div>
  </div>
</section>

<section class="evidence-band" aria-labelledby="writing-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Curated Public Writing</p>
      <h2 id="writing-heading">The feed is selective. The archive is complete.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for post in collections.posts | reverse %}
      <li>
        <p class="entry-note">
          <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
          / post{% if post.data.type %} / {{ post.data.type }}{% endif %}
        </p>
        <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        {% if post.data.description %}
        <p>{{ post.data.description }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="source-band" aria-labelledby="inventory-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Inventory</p>
      <h2 id="inventory-heading">Canonical object records.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for item in archive.inventory %}
      <li>
        <p class="entry-note">
          {{ item.id }} / {{ item.category }} / {{ item.associated_project }}
        </p>
        <h3>{{ item.name }}</h3>
        <p>{{ item.condition }}. {{ item.status }}.</p>
        <p class="entry-note">
          logged {{ item.date_logged }}{% if item.photos and item.photos.length %}
          / {{ item.photos.length }} photo{% if item.photos.length != 1 %}s{% endif %}{% endif %}
        </p>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="evidence-band" aria-labelledby="projects-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Projects</p>
      <h2 id="projects-heading">Dossiers and continuity packets.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for project in archive.projects %}
      <li>
        <p class="entry-note">
          {{ project.id }} / {{ project.category }} / {{ project.status }}
        </p>
        <h3>{{ project.title }}</h3>
        <p>{{ project.summary }}</p>
        {% if project.working_title %}
        <p class="entry-note">{{ project.working_title }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="source-band" aria-labelledby="field-log-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Field Logs</p>
      <h2 id="field-log-heading">Evidence before interpretation.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for log in archive.fieldLogs | reverse %}
      <li>
        <p class="entry-note">{{ log.id }} / {{ log.date }} / {{ log.category }}</p>
        <h3>{{ log.title }}</h3>
        <p>{{ log.object }}. {{ log.status }}.</p>
        {% if log.tags and log.tags.length %}
        <p class="entry-note">{{ log.tags | join(', ') }}</p>
        {% endif %}
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="evidence-band" aria-labelledby="source-sets-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Source Sets</p>
      <h2 id="source-sets-heading">Raw evidence registered, not flattened.</h2>
    </div>

    <ul class="link-list archive-record-list">
      <li>
        <p class="entry-note">FI-2026-06-12-L-ARCHIVE / local photo intake</p>
        <h3><a href="/docs/intake/2026-06-12-l-archive.md">L'Archive local photo dump</a></h3>
        <p>259 local media files copied into `intake/L-Archive/`; raw evidence remains unpublished until curated.</p>
      </li>
      <li>
        <p class="entry-note">FI-2026-06-05-PHOTO-SWEEP / photo evidence sets</p>
        <h3><a href="/docs/intake/2026-06-05-photo-inventory-sweep.md">First photo inventory sweep</a></h3>
        <p>Collection-level registration for the initial local photo evidence sets.</p>
      </li>
      <li>
        <p class="entry-note">2014-2026 / imported public social evidence</p>
        <h3><a href="/social-posts.html">Recovered social shelf</a></h3>
        <p>Tumblr and Instagram records with local media, source URLs, and generated Markdown.</p>
      </li>
    </ul>
  </div>
</section>

<section class="source-band" aria-labelledby="social-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Recovered Social Evidence</p>
      <h2 id="social-heading">Imported posts remain visible as source records.</h2>
    </div>

    <ul class="link-list archive-record-list">
      {% for post in archive.socialPosts | reverse %}
      <li>
        <p class="entry-note">{{ post.date }} / {{ post.source }} / {{ post.source_id }}</p>
        <h3>
          <a href="/{{ post.post_path }}">{{ post.title }}</a>
        </h3>
        <p>{{ post.body | truncate(220) }}</p>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<section class="evidence-band" aria-labelledby="machine-heading">
  <div class="section-inner band-grid">
    <div>
      <p class="section-label">Machine-Readable Archive</p>
      <h2 id="machine-heading">The source remains inspectable.</h2>
    </div>

    <ul class="link-list">
      <li>
        <h3><a href="/dist/forgotten-industries.json">forgotten-industries.json</a></h3>
        <p>Generated complete archive data.</p>
      </li>
      <li>
        <h3><a href="/dist/index.ts">index.ts</a></h3>
        <p>Generated TypeScript module for downstream consumers.</p>
      </li>
      <li>
        <h3><a href="/src/data/inventory.yml">inventory.yml</a></h3>
        <p>Canonical source for physical objects and component records.</p>
      </li>
      <li>
        <h3><a href="/src/data/field-logs.yml">field-logs.yml</a></h3>
        <p>Canonical source for structured field logs.</p>
      </li>
      <li>
        <h3><a href="/src/data/social-posts.yml">social-posts.yml</a></h3>
        <p>Canonical source for imported social evidence.</p>
      </li>
    </ul>
  </div>
</section>
