<section class="archive-curator-band" aria-labelledby="archive-curator-heading">
  <div class="section-inner">
    <aside class="archive-curator-note">
      <p id="archive-curator-heading" class="section-label">// Curator's note //</p>
      <blockquote class="archive-curator-statement">
