          <span>{{ archive.projects | pluralLabel("Dossier", "Dossiers") }}</span>
        </a>
        <a class="stat" href="/archive/objects/">
          <strong>{{ archive.inventory | countObjectsWithPhotos }}</strong>
          <span>{{ archive.inventory | countObjectsWithPhotos | pluralLabel("Object photographed", "Objects photographed") }}</span>
        </a>
        <a class="stat" href="/archive/taxonomy/">
          <strong>{{ taxonomy.allTerms | count }}</strong>
          <span>{{ taxonomy.allTerms | pluralLabel("Taxonomy term", "Taxonomy terms") }}</span>
        </a>
        <a class="stat" href="/hang-on-to-each-other/">
          <strong>1</strong>
          <span>{{ 1 | pluralLabel("Manuel", "Manuels") }}</span>
        </a>
        <a class="stat" href="/en-direct/">
          <strong>{{ fieldnotes | count }}</strong>
          <span>{{ fieldnotes | pluralLabel("En Direct record", "En Direct records") }}</span>
        </a>
        <a class="stat" href="/archive/social-evidence/">
          <strong>{{ archive.socialPosts | count }}</strong>
          <span>{{ archive.socialPosts | pluralLabel("Recovered social record", "Recovered social records") }}</span>
        </a>
        <a class="stat" href="/archive/posts/">
          <strong>{{ collections.posts | count }}</strong>
          <span>{{ collections.posts | pluralLabel("Signal entry", "Signal entries") }}</span>
        </a>
        <a class="stat" href="/archive/field-logs/">
          <strong>{{ archive.fieldLogs | count }}</strong>
          <span>{{ archive.fieldLogs | pluralLabel("ATLAS report", "ATLAS reports") }}</span>
        </a>
        <a class="stat stat-wide" href="/archive/objects/">
          <strong>{{ archive.inventory | count }}</strong>
          <span>{{ archive.inventory | pluralLabel("Object catalogued", "Objects catalogued") }}</span>
          <span class="stat-adjustment">Live canonical inventory</span>
        </a>
        <a class="stat stat-wide" href="{{ site.githubUrl }}/commits/main">
          <strong>{{ site.sourceStats.commits }}</strong>
          <span>{{ site.sourceStats.commits | pluralLabel("Git commit", "Git commits") }}</span>
          <span class="stat-adjustment" title="Change since {{ site.sourceStats.deltaSince }}">
            {{ site.sourceStats.commitDeltaLabel }}
          </span>
        </a>
      </div>
    </div>
  </div>
</section>

