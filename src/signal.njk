---
layout: base.njk
title: Le Signal
description: "The Forgotten Industries signal record: field notes, updates, observations, reports, and dispatches."
permalink: /signal/index.html
eleventyExcludeFromCollections: true
---
{% set reports = archive.fieldLogs | fieldLogsNewest %}
<section class="section-landing-hero">
  <div class="section-inner">
    <div class="spine-hero-title-block">
      <h1>Le Signal</h1>
      <p class="spine-hero-meta">// The authored record in motion.</p>
    </div>
  </div>
</section>

<section class="signal-ticker-band" aria-labelledby="signal-ticker-heading">
  <div class="section-inner">
    <div class="signal-ticker-header">
      <h2 id="signal-ticker-heading" class="sr-only">Recent signal activity</h2>
      <div class="signal-ticker-plate" aria-hidden="true">
        <p><span>/ / / / /</span> EN DIRECT <span>/ / / / /</span></p>
        <span>// Live Feed / 10 posts</span>
      </div>
    </div>
    <div class="signal-ticker" role="list" aria-label="Recent signal activity">
      {% if fieldnotes.length %}
      {% for note in fieldnotes %}
      {% if loop.index <= 4 %}
      <a class="signal-ticker-item" role="listitem" href="{{ note.url }}" data-track="outbound-field-note">
        <span>En Direct / {{ note.createdAt | readableDate }}</span>
        <strong>{{ note.text | escape }}</strong>
      </a>
      {% endif %}
      {% endfor %}
      {% endif %}
      {% for report in reports %}
      {% if loop.index <= 4 %}
      <a class="signal-ticker-item" role="listitem" href="/field-logs/{{ report.slug }}/">
        <span>ATLAS / {{ report.date | replace('-', '.') | replace('-', '.') }}</span>
        <strong>{{ report.title }}</strong>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<section class="signal-source-band" aria-labelledby="signal-directory-heading">
  <div class="section-inner">
    <h2 id="signal-directory-heading" class="sr-only">Signal sources</h2>
    <div class="signal-source-grid">
      <section class="signal-source-column" aria-labelledby="operator-signal-heading">
        <header class="signal-branch-head">
          <span class="signal-label-stack">
            <h2 id="operator-signal-heading">L'OPÉRATEUR</h2>
            <span class="signal-branch-meta">// MTM / <a href="/about.html">À PROPOS</a></span>
          </span>
        </header>
        <div class="signal-source-list">
          <a class="signal-branch-row" href="/posts/">
            <span class="signal-label-stack">
              <span class="signal-row-title">LE BLOG</span>
              <span class="signal-row-meta">// Blog ({{ collections.posts | count }})</span>
            </span>
          </a>
          <a class="signal-branch-row" href="{{ site.fieldNotesSubscribeUrl }}" data-track="outbound-bluesky">
            <span class="signal-label-stack">
              <span class="signal-row-title">EN DIRECT</span>
              <span class="signal-row-meta">// Live Feed (10)</span>
            </span>
          </a>
          <a class="signal-branch-row" href="/field-logs/">
            <span class="signal-label-stack">
              <span class="signal-row-title">LES DÉPOSITIONS</span>
              <span class="signal-row-meta">// OM-882 Audio Field Journal</span>
            </span>
          </a>
        </div>
      </section>

      <section class="signal-source-column" aria-labelledby="atlas-signal-heading">
        <header class="signal-branch-head">
          <span class="signal-label-stack">
            <h2 id="atlas-signal-heading">LE SYSTÈME</h2>
            <span class="signal-branch-meta">// ATLAS / GPT-5.5</span>
          </span>
        </header>
        <div class="signal-source-list">
          <a class="signal-branch-row" href="/atlas/">
            <span class="signal-label-stack">
              <span class="signal-row-title">LES RAPPORTS</span>
              <span class="signal-row-meta">// Field Reports ({{ archive.fieldLogs | count }})</span>
            </span>
          </a>
          <a class="signal-branch-row" href="/archive/posts/">
            <span class="signal-label-stack">
              <span class="signal-row-title">LES DOCTRINES</span>
              <span class="signal-row-meta">// Systems Doctrine ({{ collections.posts | count }})</span>
            </span>
          </a>
          <a class="signal-branch-row" href="/provenance/">
            <span class="signal-label-stack">
              <span class="signal-row-title">LA PROVENANCE</span>
              <span class="signal-row-meta">// Source Chain / Archive view</span>
            </span>
          </a>
        </div>
      </section>
    </div>
  </div>
</section>
