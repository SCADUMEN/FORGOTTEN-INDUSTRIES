{
  "name": "@forgotten-industries/archive",
  "version": "0.1.0",
  "description": "Canonical archive data for Forgotten Industries machines, parts, field logs, and restoration projects.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
