{
  "name": "@forgotten-industries/archive",
  "version": "0.1.0",
  "description": "Canonical archive data for Forgotten Industries machines, parts, field logs, and restoration projects.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.ts",
      "default": "./dist/index.ts"
    },
    "./data": "./dist/forgotten-industries.json"
  },
  "scripts": {
    "build": "ruby scripts/build.rb",
    "build:archive": "ruby scripts/build.rb",
    "build:css": "sh scripts/build_css.sh --minify",
    "build:site": "ruby scripts/build.rb && eleventy && sh scripts/build_css.sh --minify",
    "serve:site": "ruby scripts/build.rb && eleventy && sh scripts/build_css.sh && eleventy --serve",
    "pretty": "prettier --write ."
  },
  "keywords": [
    "archive",
    "restoration",
    "hardware",
    "field-notes",
    "forgotten-industries"
  ],
  "author": "Matthew Taylor Marx",
  "license": "UNLICENSED",
  "devDependencies": {
    "@11ty/eleventy": "3.1.6",
    "@11ty/eleventy-plugin-rss": "3.0.0",
    "@tailwindcss/cli": "4.3.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0",
    "tailwindcss": "4.3.0"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10.0.0"
  }
}
